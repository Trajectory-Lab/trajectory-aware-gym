# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=  # Optional, for temporary credentials

# AWS Bedrock Model IDs
BEDROCK_QWEN3_1_7B=qwen3-1.7b
BEDROCK_QWEN3_4B=qwen3-4b
BEDROCK_CLAUDE_SONNET_4_5=anthropic.claude-sonnet-4-5-v2:0

# LiteLLM Configuration
LITELLM_LOG=INFO
LITELLM_DROP_PARAMS=true

# GEPA Configuration
GEPA_BUDGET=medium  # Options: light, medium, heavy
GEPA_POPULATION_SIZE=6
GEPA_ITERATIONS=75
GEPA_REFLECTION_MODEL=anthropic.claude-sonnet-4-5-v2:0

# GEM Configuration
GEM_MAX_STEPS=50
GEM_TEMPERATURE_TRAIN=1.0
GEM_TEMPERATURE_EVAL=0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/training.log

# Experiment Configuration
EXPERIMENT_NAME=baseline_experiment
RANDOM_SEED=42
NUM_REPLICATIONS=3

# S3 Storage (for trajectory logs and results)
S3_BUCKET=trajectory-aware-gym-results
S3_PREFIX=experiments/

# Cost Tracking
TRACK_COSTS=true
COST_ALERT_THRESHOLD=100.0  # USD
