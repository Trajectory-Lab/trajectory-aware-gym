# ============================================================
# .env — Secrets and per-developer overrides
# Non-sensitive defaults live in src/trajectory_aware_gym/config/trajectory-aware-gym.yaml
# Env vars override YAML using PREFIX_FIELD convention
# ============================================================

# AWS Credentials (REQUIRED for Bedrock models)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN=  # optional, for temporary credentials

# LiteLLM (read by litellm directly, not our config)
LITELLM_LOG=INFO
LITELLM_DROP_PARAMS=true

# SageMaker (REQUIRED for SageMaker deployment)
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/your-sagemaker-role

# Override any YAML value, e.g.:
# GEM_MAX_STEPS=100
# GEPA_NUM_THREADS=8
# AWS_REGION=eu-west-1
# OLLAMA_API_BASE=http://localhost:11434
# LOG_LEVEL=DEBUG
