# AWS Configuration
AWS_REGION=us-east-1
AWS_BEARER_TOKEN_BEDROCK=your_access_key_here

# AWS Bedrock Model IDs (using inference profiles)
BEDROCK_LLAMA_1B=us.meta.llama3-2-1b-instruct-v1:0
BEDROCK_LLAMA_3B=us.meta.llama3-2-3b-instruct-v1:0
BEDROCK_LLAMA_8B=us.meta.llama3-1-8b-instruct-v1:0

# LiteLLM Configuration
LITELLM_LOG=INFO
LITELLM_DROP_PARAMS=true

# GEPA Configuration
GEPA_BUDGET=medium  # Options: light, medium, heavy
GEPA_POPULATION_SIZE=6
GEPA_ITERATIONS=75
GEPA_REFLECTION_MODEL=anthropic.claude-sonnet-4-5-v2:0

# GEM Configuration
GEM_MAX_STEPS=50
GEM_TEMPERATURE_TRAIN=1.0
GEM_TEMPERATURE_EVAL=0.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/training.log

# Experiment Configuration
EXPERIMENT_NAME=baseline_experiment
RANDOM_SEED=42
NUM_REPLICATIONS=3

# S3 Storage (for trajectory logs and results)
S3_BUCKET=trajectory-aware-gym-results
S3_PREFIX=experiments/

# Cost Tracking
TRACK_COSTS=true
COST_ALERT_THRESHOLD=100.0  # USD
